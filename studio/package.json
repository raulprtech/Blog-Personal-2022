{
  "name": "raul-pacheco-sanity-studio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "import:initial": "sanity datasets import --project-id a668buu6 --dataset production --replace import/initial-content.ndjson",
    "import:initial:missing": "sanity datasets import --project-id a668buu6 --dataset production --missing import/initial-content.ndjson",
    "verify:production": "sanity documents query --project-id a668buu6 --dataset production \"*[]{_id,_type,title,slug}[0...30]\" --pretty",
    "verify:site-settings": "sanity documents query --project-id a668buu6 --dataset production \"*[_type == \\\"siteSettings\\\"]{_id,_type,title,headerTitle,cvHref,socialLinks}\" --pretty"
  },
  "dependencies": {
    "@sanity/vision": "latest",
    "sanity": "latest",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "react": "^19.2.2",
    "react-dom": "^19.2.2"
  }
}
